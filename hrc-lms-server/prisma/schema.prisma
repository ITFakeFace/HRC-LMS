generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = "mysql://root:DoThanhHung66%404@localhost:3306/KLTN_HRC_JS"
}

// =========================================================================
//                                CORE MODELS
// =========================================================================

model User {
  id                Int            @id @default(autoincrement())
  pID               String         @unique @db.VarChar(12)
  username          String         @unique @db.VarChar(50)
  phone             String?        @unique @db.VarChar(10)
  email             String         @unique @db.VarChar(100)
  password          String         @db.VarChar(255)
  avatar            String?
  fullname          String         @db.VarChar(100)
  gender            Boolean
  dob               DateTime
  lockoutEnd        DateTime?
  isEmailVerified   Boolean        @default(false)
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  // Mối quan hệ N:N với Role (Bảng liên kết ngầm định: UserToRole)
  roles             Role[]         @relation("UserRoles")

  refreshTokens     RefreshToken[]

  // Mối quan hệ 1:N với Course
  createdCourses    Course[]       @relation("CreatedCourses")
  editedCourses     Course[]       @relation("EditedCourses")
  
  sentMessages ChatContent[]

  // --- QUAN HỆ MỚI (CLASS & ATTENDANCE) ---
  
  // 1. User là Học viên tham gia các lớp
  enrollments     Enrollment[]

  // 2. User là Giáo viên mở form điểm danh
  openedSessions  AttendanceSession[] @relation("SessionOpener")

  // 3. User là Học viên được điểm danh (để truy vấn lịch sử điểm danh của user này)
  attendanceRecords AttendanceRecord[]

  @@map("Users") // Đặt tên bảng MySQL là Users
}

model Role {
  id          Int            @id @default(autoincrement())
  fullname    String         @unique @db.VarChar(50)
  shortname   String         @unique @db.VarChar(15)

  // Mối quan hệ N:N với User
  users       User[]         @relation("UserRoles")

  // Quan hệ phân cấp Tự tham chiếu N:N (Sử dụng bảng liên kết tường minh RoleHierarchy)
  parentRoles RoleHierarchy[] @relation("ParentOf") // Vai trò: Là Role cha
  childRoles  RoleHierarchy[] @relation("ChildOf")  // Vai trò: Là Role con

  // Mối quan hệ N:N với Permission (Bảng liên kết ngầm định: RoleToPermission)
  permissions Permission[]   @relation("RolePermissions")

  @@map("Roles") // Đặt tên bảng MySQL là Roles
}

model RoleHierarchy {
  parentId Int
  childId  Int

  // Đổi tên relation để phù hợp với ngữ cảnh Parent/Child
  parent Role @relation("ParentOf", fields: [parentId], references: [id], onDelete: Cascade)
  child  Role @relation("ChildOf", fields: [childId], references: [id], onDelete: Cascade)

  @@id([parentId, childId])
  @@map("RoleHierarchies") // Đặt tên bảng liên kết là RoleHierarchies
}

model Permission {
  id          Int      @id @default(autoincrement())
  name        String   @unique @db.VarChar(100)
  description String?  @db.VarChar(255)

  // Mối quan hệ N:N với Role
  roles       Role[]   @relation("RolePermissions")

  @@map("Permissions") // Đặt tên bảng MySQL là Permissions
}

// =========================================================================
//                             OTHER MODELS
// =========================================================================

model RefreshToken {
  id                Int      @id @default(autoincrement())
  jti               String   @unique 
  userId            Int
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  isRevoked         Boolean  @default(false)
  replacedByTokenId String?  
  createdAt         DateTime @default(now())
  expiresAt         DateTime
  ipAddress         String?  
  userAgent         String?  

  @@index([userId])
  @@map("RefreshTokens")
}

model Course {
  id          Int      @id @default(autoincrement())
  
  // --- NHÓM ĐỊNH DANH & TÌM KIẾM (Cột cứng - Indexed) ---
  name        String   @db.VarChar(255)
  code        String   @unique @db.VarChar(50)  // Ví dụ: "HRC-RS01" -> Dùng để tìm kiếm chính xác
  slug        String   @unique @db.VarChar(255) // Ví dụ: "thu-hut-va-tuyen-chon-nhan-su" -> Dùng cho URL
  status      Int      @default(0)              // 0: Draft, 1: Published
  
  description String?  @db.Text                 // Dùng Text thay vì VarChar để lưu được nhiều hơn
  duration    String?  @db.VarChar(255)         // Lưu chuỗi: "10 buổi, mỗi buổi 2.5 giờ"
  coverImage  Bytes?                            // Lưu ảnh cover (Base64 -> Buffer)

  // --- NHÓM JSON (Lưu trữ linh hoạt - Flexible) ---
  
  // Mảng String: ["Mục tiêu 1", "Mục tiêu 2"...]
  objectives  Json     @map("objectives")      // Tên cũ: courseObjectives
  
  // Mảng String: ["Người học A", "Người học B"...]
  audiences   Json?    @map("audiences")       // Tên cũ: targetLearners
  
  // Mảng String: ["Yêu cầu 1"...]
  requirements Json?
  
  // Mảng String: ["Thứ 7...", "Thứ 2..."]
  schedule     Json?
  
  // Mảng String: ["Cơ sở 1", "Cơ sở 2"]
  locations    Json?
  
  // Object: { "part_exam": "...", "final_exam": "..." }
  assessment   Json?    @map("assessment")     // Tên cũ: assessmentMethods
  
  // Object: { "mandatory": "...", "references": "..." }
  materials    Json?
  
  // Mảng Object (QUAN TRỌNG: Cần chuẩn hóa từ Object key động sang Mảng)
  // [ { "title": "Buổi 1", "topics": ["A", "B"] }, ... ]
  contents     Json?

  // Mảng String: ["Giảng viên A", "Giảng viên B"] 
  // (Nếu sau này cần quản lý giảng viên chặt chẽ thì tách bảng riêng, còn hiện tại lưu tên thì dùng JSON)
  instructors  Json?

  // --- QUAN HỆ & METADATA ---
  creatorId    Int
  lastEditor   Int?     // Có thể null nếu chưa ai sửa

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  creator      User     @relation("CreatedCourses", fields: [creatorId], references: [id])
  editor       User?    @relation("EditedCourses", fields: [lastEditor], references: [id])
  // Mối quan hệ N:N với Category
  categories   Category[] @relation("CourseCategories")
  // --- QUAN HỆ MỚI ---
  // Một khóa học (template) có nhiều lớp học (instances)
  classes     Class[]
  

  @@map("Courses")
}

model Category {
  id          Int      @id @default(autoincrement())
  name        String   @unique @db.VarChar(255)
  description String?  @db.VarChar(255)

  // Mối quan hệ N:N với Course
  courses     Course[] @relation("CourseCategories")

  @@map("Categories")
}

// 2. Bảng ClientSession (Phiên chat của khách)
model ClientSession {
  id        Int       @id @default(autoincrement())
  AIEnable  Boolean   @default(true) // Mặc định bật AI
  isEnded   Boolean   @default(false) // Mặc định chưa kết thúc
  createdAt DateTime  @default(now())

  // Mối quan hệ 1:N với ChatContent (1 phiên có nhiều tin nhắn)
  messages ChatContent[]

  @@map("ClientSessions")
}

// 3. Bảng ChatContent (Nội dung chat)
model ChatContent {
  id        Int      @id @default(autoincrement())
  message   String   @db.VarChar(255)
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  // --- QUAN HỆ 1: PHIÊN CHAT (BẮT BUỘC) ---
  // Tin nhắn này thuộc về phiên chat nào?
  sessionId Int
  session   ClientSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  // --- QUAN HỆ 2: NGƯỜI GỬI (LÀ USER/AI) ---
  // Ai gửi tin nhắn này? (Có thể Null)
  // - Nếu senderId = NULL  => Người gửi là KHÁCH (Guest/ClientSession owner)
  // - Nếu senderId = VALUE => Người gửi là USER (Có thể là AI hoặc Agent)
  senderId Int?
  sender   User? @relation(fields: [senderId], references: [id], onDelete: SetNull)

  @@map("ChatContents")
}

// MODEL MỚI: Lớp học cụ thể
model Class {
  id          Int      @id @default(autoincrement())
  code        String   @unique @db.VarChar(50) // Mã lớp, VD: "HRC-RS01-K19"
  name        String   @db.VarChar(255)        // Tên lớp
  startDate   DateTime
  endDate     DateTime?
  status      ClassStatus @default(ACTIVE)     // Enum trạng thái lớp

  // Quan hệ với Course
  courseId    Int
  course      Course   @relation(fields: [courseId], references: [id])

  // Quan hệ: Một lớp có nhiều học viên đăng ký
  enrollments Enrollment[]

  // Quan hệ: Một lớp có nhiều buổi điểm danh
  attendanceSessions AttendanceSession[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("Classes")
}

// MODEL MỚI: Đăng ký học (Bảng trung gian User - Class)
model Enrollment {
  id        Int      @id @default(autoincrement())
  studentId Int
  classId   Int
  joinedAt  DateTime @default(now())
  status    EnrollmentStatus @default(LEARNING) // Đang học, Bảo lưu, Đã xong...

  student   User     @relation(fields: [studentId], references: [id])
  class     Class    @relation(fields: [classId], references: [id])

  // Ràng buộc: Một User chỉ đăng ký 1 Class một lần
  @@unique([studentId, classId]) 
  @@map("Enrollments")
}

// =========================================================================
//                              ATTENDANCE MODELS
// =========================================================================

// MODEL MỚI: Phiên điểm danh (Cái Form giáo viên mở)
model AttendanceSession {
  id        Int      @id @default(autoincrement())
  
  // Thuộc về lớp nào?
  classId   Int
  class     Class    @relation(fields: [classId], references: [id])

  // Ai mở form? (Teacher)
  openBy    Int
  opener    User     @relation("SessionOpener", fields: [openBy], references: [id])

  // Thời gian
  openAt    DateTime @default(now())
  closeAt   DateTime? // Nếu null nghĩa là đang mở, chưa đóng

  // Mã phiên (Optional): Dùng nếu muốn sinh code cho học sinh tự nhập
  code      String?  @db.VarChar(10) 

  // Danh sách các bản ghi điểm danh trong phiên này
  records   AttendanceRecord[]

  @@map("AttendanceSessions")
}

// MODEL MỚI: Bản ghi điểm danh chi tiết (Cho từng học sinh)
model AttendanceRecord {
  id        Int      @id @default(autoincrement())

  // Thuộc về phiên điểm danh nào?
  sessionId Int
  session   AttendanceSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  // Điểm danh cho học sinh nào?
  stdId     Int
  student   User     @relation(fields: [stdId], references: [id])

  // Trạng thái: Có mặt, Vắng, Muộn...
  status    AttendanceStatus @default(ABSENT) 
  
  // Ghi chú (VD: Lý do vắng)
  note      String?  @db.VarChar(255)
  
  updatedAt DateTime @updatedAt // Thời điểm cập nhật trạng thái

  // Ràng buộc: Trong 1 phiên, 1 học sinh chỉ có 1 bản ghi
  @@unique([sessionId, stdId])
  @@map("AttendanceRecords")
}

// =========================================================================
//                                ENUMS
// =========================================================================

enum ClassStatus {
  ACTIVE
  FINISHED
  CANCELED
}

enum EnrollmentStatus {
  LEARNING
  DROPPED
  PASSED
  FAILED
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  EXCUSED // Có phép
}