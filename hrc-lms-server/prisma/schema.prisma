// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = "mysql://root:123456@localhost:3306/KLTN_HRC_JS"
}

// =========================================================================
//                              CORE MODELS (USER & AUTH)
// =========================================================================

model User {
  id              Int       @id @default(autoincrement())
  pID             String    @unique @db.VarChar(12)
  username        String    @unique @db.VarChar(50)
  phone           String?   @unique @db.VarChar(10)
  email           String    @unique @db.VarChar(100)
  password        String    @db.VarChar(255)
  avatar          String?
  fullname        String    @db.VarChar(100)
  gender          Boolean
  dob             DateTime
  lockoutEnd      DateTime?
  isEmailVerified Boolean   @default(false)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // --- QUAN HỆ HỆ THỐNG ---
  roles           Role[]         @relation("UserRoles")
  refreshTokens   RefreshToken[]
  sentMessages    ChatContent[]

  // --- QUAN HỆ KHÓA HỌC (Quản lý) ---
  createdCourses  Course[]       @relation("CreatedCourses")
  editedCourses   Course[]       @relation("EditedCourses")

  // --- QUAN HỆ LỚP HỌC & ĐIỂM DANH ---
  
  // 1. Với tư cách HỌC VIÊN
  enrollments     Enrollment[]
  attendanceRecords AttendanceRecord[] // Lịch sử đi học của user này

  // 2. Với tư cách GIẢNG VIÊN (TEACHER)
  lecturedClasses Class[]            @relation("ClassLecturer") // Các lớp được phân công dạy
  openedSessions  ClassSession[]     @relation("SessionOpener") // Các buổi học mà user này đã bấm "Mở điểm danh"
  formRequests    FormRequest[] // Danh sách yêu cầu đã gửi
  errorReports    ErrorReport[] // Danh sách báo lỗi đã gửi

  @@map("Users")
}

model Role {
  id          Int             @id @default(autoincrement())
  fullname    String          @unique @db.VarChar(50)
  shortname   String          @unique @db.VarChar(15)
  users       User[]          @relation("UserRoles")
  
  parentRoles RoleHierarchy[] @relation("ParentOf")
  childRoles  RoleHierarchy[] @relation("ChildOf")
  permissions Permission[]    @relation("RolePermissions")

  @@map("Roles")
}

model RoleHierarchy {
  parentId Int
  childId  Int
  parent   Role @relation("ParentOf", fields: [parentId], references: [id], onDelete: Cascade)
  child    Role @relation("ChildOf", fields: [childId], references: [id], onDelete: Cascade)

  @@id([parentId, childId])
  @@map("RoleHierarchies")
}

model Permission {
  id          Int     @id @default(autoincrement())
  name        String  @unique @db.VarChar(100)
  description String? @db.VarChar(255)
  roles       Role[]  @relation("RolePermissions")

  @@map("Permissions")
}

model RefreshToken {
  id                Int      @id @default(autoincrement())
  jti               String   @unique 
  userId            Int
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  isRevoked         Boolean  @default(false)
  replacedByTokenId String?  
  createdAt         DateTime @default(now())
  expiresAt         DateTime
  ipAddress         String?  
  userAgent         String?  

  @@index([userId])
  @@map("RefreshTokens")
}

// =========================================================================
//                              COURSE & CLASS MANAGEMENT
// =========================================================================

model Course {
  id          Int      @id @default(autoincrement())
  
  // Metadata
  name        String   @db.VarChar(255)
  code        String   @unique @db.VarChar(50)
  slug        String   @unique @db.VarChar(255)
  status      Int      @default(0) // 0: Draft, 1: Published
  description String?  @db.Text
  duration    String?  @db.VarChar(255)
  coverImage  String?  

  // Flexible JSON Data
  objectives   Json     @map("objectives")
  audiences    Json?    @map("audiences")
  requirements Json?
  schedule     Json?
  locations    Json?
  assessment   Json?    @map("assessment")
  materials    Json?
  contents     Json?
  instructors  Json?

  // Relations
  creatorId    Int
  lastEditor   Int?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  creator      User     @relation("CreatedCourses", fields: [creatorId], references: [id])
  editor       User?    @relation("EditedCourses", fields: [lastEditor], references: [id])
  categories   Category[] @relation("CourseCategories")
  
  // Quan hệ với Lớp học (Instances)
  classes      Class[]

  @@map("Courses")
}

model Category {
  id          Int      @id @default(autoincrement())
  name        String   @unique @db.VarChar(255)
  description String?  @db.VarChar(255)
  courses     Course[] @relation("CourseCategories")

  @@map("Categories")
}

// MODEL CLASS: Lớp học cụ thể
model Class {
  id            Int         @id @default(autoincrement())
  code          String      @unique @db.VarChar(50) 
  name          String      @db.VarChar(255)
  
  // --- CẤU HÌNH LỊCH HỌC (Dùng để sinh ClassSession) ---
  startDate     DateTime    // Ngày khai giảng
  endDate       DateTime?   // Ngày bế giảng (null nếu tính theo số buổi)
  totalSessions Int         @default(0) 
  
  shift         ClassShift  // Ca học: MWF (2-4-6) hoặc TTS (3-5-7)
  startTime     String      @default("18:00") 
  endTime       String      @default("21:30") 

  status        ClassStatus @default(UPCOMING)

  // --- QUAN HỆ ---
  courseId      Int
  course        Course      @relation(fields: [courseId], references: [id])

  // Giảng viên chính thức của lớp
  lecturerId    Int?
  lecturer      User?       @relation("ClassLecturer", fields: [lecturerId], references: [id])

  // Danh sách học viên
  enrollments   Enrollment[]

  // Danh sách Lịch học / Buổi học thực tế
  sessions      ClassSession[]

  

  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@map("Classes")
}

// MODEL ENROLLMENT: Danh sách đăng ký
model Enrollment {
  id        Int              @id @default(autoincrement())
  studentId Int
  classId   Int
  joinedAt  DateTime         @default(now())
  status    EnrollmentStatus @default(LEARNING) 

  student   User             @relation(fields: [studentId], references: [id])
  class     Class            @relation(fields: [classId], references: [id])

  @@unique([studentId, classId]) 
  @@map("Enrollments")
}

// =========================================================================
//                              SCHEDULE & ATTENDANCE
// =========================================================================

// MODEL CLASS SESSION: Vừa là Lịch Học, Vừa là Phiên Điểm Danh
model ClassSession {
  id             Int           @id @default(autoincrement())
  
  classId        Int
  class          Class         @relation(fields: [classId], references: [id], onDelete: Cascade)

  // --- THÔNG TIN LỊCH (Schedule) ---
  sessionNumber  Int           // Buổi số 1, 2, 3...
  date           DateTime      // Ngày học
  startTime      DateTime      // Thời gian bắt đầu (DateTime đầy đủ)
  endTime        DateTime      // Thời gian kết thúc (DateTime đầy đủ)
  title          String?       // Chủ đề buổi học (nếu có)
  description    String?       @db.Text

  // --- THÔNG TIN ĐIỂM DANH (Attendance Execution) ---
  status         SessionStatus @default(SCHEDULED) // SCHEDULED -> ONGOING -> FINISHED
  
  isAttendanceOpen Boolean     @default(false)     // Đang mở cho quét QR không?
  attendanceCode   String?     @db.VarChar(10)     // Mã OTP (nếu cần)

  // Ai là người kích hoạt buổi học này?
  openedBy       Int?
  opener         User?         @relation("SessionOpener", fields: [openedBy], references: [id])

  // Danh sách kết quả điểm danh của sinh viên
  records        AttendanceRecord[]

  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([classId, date])
  @@map("ClassSessions")
}

// MODEL ATTENDANCE RECORD: Chi tiết điểm danh của từng sinh viên
model AttendanceRecord {
  id        Int              @id @default(autoincrement())

  // Liên kết trực tiếp với Session
  sessionId Int
  session   ClassSession     @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  // Liên kết với Sinh viên
  stdId     Int
  student   User             @relation(fields: [stdId], references: [id])

  // Trạng thái & Kết quả
  status    AttendanceStatus @default(ABSENT) 
  note      String?          @db.VarChar(255)
  checkInAt DateTime?        // Thời gian thực tế quét QR

  updatedAt DateTime         @updatedAt

  @@unique([sessionId, stdId]) // Một sinh viên chỉ có 1 record trong 1 buổi
  @@map("AttendanceRecords")
}

// =========================================================================
//                              CHAT & CLIENT SUPPORT
// =========================================================================

model ClientSession {
  id        Int           @id @default(autoincrement())
  AIEnable  Boolean       @default(true)
  isEnded   Boolean       @default(false)
  createdAt DateTime      @default(now())
  messages  ChatContent[]

  @@map("ClientSessions")
}

model ChatContent {
  id        Int           @id @default(autoincrement())
  message   String        @db.VarChar(255)
  isRead    Boolean       @default(false)
  createdAt DateTime      @default(now())

  sessionId Int
  session   ClientSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  senderId  Int?
  sender    User?         @relation(fields: [senderId], references: [id], onDelete: SetNull)

  @@map("ChatContents")
}

// 1. Bảng Yêu cầu biểu mẫu (FormRequest)
model FormRequest {
  id          Int      @id @default(autoincrement())
  
  // Thông tin yêu cầu
  title       String   @db.VarChar(255) // Tiêu đề: "Xin bảng điểm", "Dời lịch thi"
  content     String   @db.Text         // Nội dung chi tiết
  image       String?                   // Ảnh minh chứng (nếu có)
  
  // Trạng thái xử lý
  status      RequestStatus @default(PENDING)
  adminNote   String?  @db.Text         // Ghi chú của admin (VD: Lý do từ chối)
  
  // Thời gian
  createdAt   DateTime @default(now())
  resolvedAt  DateTime?                 // Ngày giải quyết xong
  
  // Người gửi yêu cầu
  userId      Int
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("FormRequests")
}

// 2. Bảng Báo lỗi (ErrorReport)
model ErrorReport {
  id          Int      @id @default(autoincrement())
  
  // Thông tin báo lỗi
  title       String   @db.VarChar(255) // Tiêu đề lỗi: "Lỗi đăng nhập", "Crash app"
  content     String   @db.Text         // Mô tả lỗi, các bước tái hiện
  image       String?                   // Ảnh chụp màn hình lỗi
  
  // Trạng thái xử lý
  status      RequestStatus @default(PENDING)
  adminReply  String?  @db.Text         // Phản hồi của admin cho user
  
  // Thời gian
  createdAt   DateTime @default(now())
  resolvedAt  DateTime?                 // Ngày fix xong bug
  
  // Người báo lỗi
  userId      Int
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("ErrorReports")
}

// =========================================================================
//                                ENUMS
// =========================================================================

enum ClassShift {
  MWF_EVENING // Thứ 2-4-6 (18:00 - 21:30)
  TTS_EVENING // Thứ 3-5-7 (18:00 - 21:30)
}

enum ClassStatus {
  UPCOMING // Sắp mở
  ACTIVE   // Đang diễn ra
  FINISHED // Đã kết thúc
  CANCELED // Đã hủy
}

enum SessionStatus {
  SCHEDULED // Đã lên lịch, chưa học
  ONGOING   // Đang học (Giáo viên đã bấm Start)
  FINISHED  // Đã học xong
  CANCELED  // Buổi học bị hủy/nghỉ
}

enum EnrollmentStatus {
  LEARNING
  DROPPED
  PASSED
  FAILED
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  EXCUSED
}

enum RequestStatus {
  PENDING   // Đang chờ xử lý
  RESOLVED  // Đã giải quyết / Đã duyệt
  REJECTED  // Đã từ chối / Không hợp lệ
}